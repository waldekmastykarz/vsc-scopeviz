{
  "name": "scopeviz",
  "displayName": "Scope readout preview",
  "description": "Visualizes Scope readout JSON files — answers 'Does my extension help or harm?' and 'What do I change where?'",
  "version": "0.3.0",
  "publisher": "waldek",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/waldekmastykarz/vsc-scopeviz.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Visualization"
  ],
  "extensionDependencies": [
    "waldek.atif-visualizer"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "scopeviz.preview",
        "displayName": "Scope Readout Preview",
        "priority": "option",
        "selector": [
          {
            "filenamePattern": "*.json"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "scopeviz.preview",
        "title": "Scope readout preview: Open Readout Preview",
        "icon": "$(graph-line)"
      },
      {
        "command": "scopeviz.showSource",
        "title": "Scope readout preview: Show Source",
        "icon": "$(file-code)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .json && activeCustomEditorId != scopeviz.preview",
          "command": "scopeviz.preview",
          "group": "navigation"
        },
        {
          "when": "activeCustomEditorId == scopeviz.preview",
          "command": "scopeviz.showSource",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
