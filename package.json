{
  "name": "scopeviz",
  "displayName": "Scopeviz",
  "description": "Visualizes Scope readout JSON files — answers 'Does my extension help or harm?' and 'What do I change where?'",
  "version": "0.0.1",
  "publisher": "waldek",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/waldekmastykarz/vsc-scopeviz.git"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Visualization"
  ],
  "extensionDependencies": [
    "waldek.atif-visualizer"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scopeviz.preview",
        "title": "Scopeviz: Open Readout Preview",
        "icon": "$(graph-line)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .json",
          "command": "scopeviz.preview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.2.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  }
}
